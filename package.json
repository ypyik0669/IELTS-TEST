{
  "name": "ielts-couple-app",
  "version": "0.1.0",
  "private": true,
  "description": "IELTS couple learning system with free-model-first AI.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "cross-env AI_DIRECT_MODE=true pnpm --parallel --filter @ielts/web --filter @ielts/api --filter @ielts/ai-gateway dev",
    "dev:queue": "pnpm --parallel --filter @ielts/web --filter @ielts/api --filter @ielts/ai-gateway --filter @ielts/worker dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "format": "pnpm -r format"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "cross-env": "^10.1.0",
    "typescript": "^5.9.2"
  }
}
